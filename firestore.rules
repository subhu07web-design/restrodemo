rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'admin@restaurant.com' ||
        request.auth.token.email == 'daskajaldas780@gmail.com'
      );
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Menu Items Collection
    match /menu_items/{itemId} {
      // Anyone (including guest/unregistered visitors) can view the menu items
      allow read: if true;
      // Only authenticated Admins can create, update, or delete menu items
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Allow order creation as long as total amount is positive
      allow create: if request.resource.data.totalAmount > 0;
      
      // Admins can view all orders.
      // Registered customers can only view their own orders (matched by email or user ID).
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.get('customerEmail', '') == request.auth.token.email ||
          resource.data.get('userId', '') == request.auth.uid
        )
      );
      
      // Admins can transition order status to any state.
      // Customers can only update their own order to cancel it ('Cancelled') when the current status is 'Pending'.
      allow update: if isAdmin() || (
        isSignedIn() && 
        (resource.data.get('customerEmail', '') == request.auth.token.email || resource.data.get('userId', '') == request.auth.uid) &&
        resource.data.status == 'Pending' && 
        request.resource.data.status == 'Cancelled' &&
        // Prevent tampering with other fields during cancellation
        request.resource.data.items == resource.data.items &&
        request.resource.data.totalAmount == resource.data.totalAmount
      );
    }

    // Table Reservations Collection
    match /reservations/{reservationId} {
      // Anyone can request a table booking
      allow create: if true;
      // Admins can read/write all, users can read their own
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.get('email', '') == request.auth.token.email ||
          resource.data.get('userId', '') == request.auth.uid
        )
      );
      allow update, delete: if isAdmin();
    }

    // Customer Reviews Collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Anyone can create a review
      allow create: if true;
      // Only admins can delete or update reviews
      allow update, delete: if isAdmin();
    }
  }
}
